# ════════════════════════════════════════════════
# PITCHLY BACKEND — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub
# ════════════════════════════════════════════════

# ── AI (Google AI Studio — free tier) ────────────────────────────────
# Get your key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Supabase (auth + database + video storage) ────────────────────────
# All three found at: Supabase Dashboard → Settings → API
# Database URL found at: Supabase Dashboard → Settings → Database → URI tab
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=videos
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.your_project_id.supabase.co:5432/postgres

# ── App Configuration ─────────────────────────────────────────────────
# In development: http://localhost:5173
# In production: your Vercel URL (e.g. https://pitchly.vercel.app)
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# ── AI Models ─────────────────────────────────────────────────────────
# Whisper model size: tiny (75MB) | base (142MB) | small (244MB) | medium (769MB)
# Use "small" for best speed/accuracy balance on Railway free tier
WHISPER_MODEL=small

# ── Upload Limits ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=52428800
MAX_SESSION_DURATION_S=300
